{
  "name": "deep-clean-pro",
  "version": "1.0.4",
  "main": "main.js",
  "author": "Raz1ner",
  "copyright": "Copyright © 2026 Raz1ner",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder"
  },
  "build": {
    "appId": "com.Raz1ner.Deep-Clean-Pro",
    "productName": "Deep Clean Pro",
    "artifactName": "${productName}-${version}-${os}.${ext}",
    "mac": {
      "category": "public.app-category.utilities",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "universal"
          ]
        }
      ],
      "icon": "build/icon.icns",
      "hardenedRuntime": true,
      "gatekeeperAssess": false
    },
    "electronLanguages": [
      "en"
    ],
    "directories": {
      "output": "dist"
    },
    "publish": null
  },
  "dependencies": {
    "keytar": "^7.9.0"
  },
  "devDependencies": {
    "electron": "^42.2.0",
    "electron-builder": "^26.8.1"
  }
}
